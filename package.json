{
  "name": "zalo-agent-cli",
  "version": "1.0.14",
  "description": "CLI tool for Zalo automation — multi-account, proxy support, bank transfers, QR payments",
  "type": "module",
  "bin": {
    "zalo-agent": "src/index.js"
  },
  "main": "./src/index.js",
  "files": [
    "src/",
    "LICENSE",
    "DISCLAIMER.md"
  ],
  "scripts": {
    "test": "node --test src/*.test.js src/**/*.test.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "release": "npm version patch -m 'release: v%s' && git push origin main --tags"
  },
  "keywords": [
    "zalo",
    "cli",
    "automation",
    "messaging",
    "vietnam",
    "proxy",
    "vietqr",
    "zca-js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PhucMPham/zalo-agent-cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "https-proxy-agent": "^8.0.0",
    "node-fetch": "^3.3.0",
    "zca-js": "^2.1.1"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1"
  }
}
